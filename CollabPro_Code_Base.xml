<file path="collab-board/apps/web/src/features/boards/types.ts">
// collab-board/apps/web/src/features/boards/types.ts

export interface BoardPosition {
  x: number;
  y: number;
}

export interface TextBoard {
  id: string;
  type: "text";
  position: BoardPosition;
  name: string;
  createdBy: string;
  createdAt: number;
}

