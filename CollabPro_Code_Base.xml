                <ToolBtn onClick={()=>onExpand("horizontal")} title="Expand canvas right"><ChevronRight className="w-4 h-4"/></ToolBtn>
                <ToolBtn onClick={()=>onExpand("vertical")} title="Expand canvas down"><ChevronDown className="w-4 h-4"/></ToolBtn>
