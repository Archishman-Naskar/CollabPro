<file path="collab-board/apps/web/src/app/room/[roomCode]/RoomClient.tsx">
"use client";

import { useState, useCallback, useRef, useEffect } from "react";
import { YjsProvider, useYjs } from "@/lib/yjs/provider";
import RoomShell from "./RoomShell";

type Membership = { role: string; canWrite: boolean; canVideo: boolean };

// ─── PermissionWatcher ───────────────────────────────────────────────────────
// Sits inside YjsProvider so it can access useYjs().
// Watches the "permissionVersion" Y.Map. When the version increments,
// it fetches a fresh Hocuspocus token and calls onTokenRefresh so the
// provider reconnects with up-to-date permissions.

function PermissionWatcher({
  roomId,
  onTokenRefresh,
}: {
  roomId: string;
  onTokenRefresh: (token: string, membership: Membership) => void;
}) {
  const { ydoc, isAuthenticated } = useYjs();
  const lastVersionRef = useRef<number | null>(null);
  const isFetchingRef = useRef(false);

  useEffect(() => {
    if (!isAuthenticated) return;

    const permMap = ydoc.getMap("permissionVersion");

    const handler = () => {
      const v = (permMap.get("version") as number) ?? 0;

      // On first observation after connect, just record the current version.
      // We don't want to reconnect on the initial sync.
      if (lastVersionRef.current === null) {
        lastVersionRef.current = v;
        return;
      }

      // No change — nothing to do.
      if (v <= lastVersionRef.current) return;
      lastVersionRef.current = v;

      // Prevent concurrent fetches
      if (isFetchingRef.current) return;
      isFetchingRef.current = true;

      fetch(`/api/rooms/${roomId}/token`, { method: "POST" })
        .then((res) => (res.ok ? res.json() : null))
        .then((data) => {
          if (data?.token) onTokenRefresh(data.token, data.membership);
        })
        .catch(console.error)
        .finally(() => {
          isFetchingRef.current = false;
        });
    };

    permMap.observe(handler);
    return () => permMap.unobserve(handler);
    // onTokenRefresh is stable (wrapped in useCallback in parent)
  }, [ydoc, isAuthenticated, roomId, onTokenRefresh]);

  return null;
}

// ─── RoomClient ──────────────────────────────────────────────────────────────

interface RoomClientProps {
  roomCode: string;
  roomId: string;
  roomName: string;
  token: string;
  user: { id: string; name: string | null; image: string | null };
  membership: Membership;
}

export default function RoomClient({
  roomCode,
  roomId,
  roomName,
  token: initialToken,
  user,
  membership: initialMembership,
}: RoomClientProps) {
  const [token, setToken] = useState(initialToken);
  const [membership, setMembership] = useState(initialMembership);

  // Stable callback — won't cause PermissionWatcher's useEffect to re-run.
  const handleTokenRefresh = useCallback(
    (newToken: string, newMembership: Membership) => {
      setToken(newToken);
      setMembership(newMembership);
    },
    []
  );

  // Changing `token` causes YjsProvider's internal useEffect to re-run,
  // which destroys the old provider and creates a new one with fresh permissions.
  return (
    <YjsProvider roomCode={roomCode} token={token} user={user}>
      <PermissionWatcher roomId={roomId} onTokenRefresh={handleTokenRefresh} />
      <RoomShell
        roomCode={roomCode}
        roomId={roomId}
        roomName={roomName}
        user={user}
        membership={membership}
      />
    </YjsProvider>
  );
}
</file>

